# Video2Notes-AI — .gitignore

# --- Python bytecode & caches ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# --- Distribution / packaging ---
*.egg
*.egg-info/
build/
dist/
wheels/
*.whl
pip-wheel-metadata/

# --- Testing & coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/

# --- Linters / formatters ---
.ruff_cache/
.mypy_cache/
.dmypy.json
.pyre/

# --- Virtual environments ---
env/
.venv/
venv/
ENV/
env.bak/
venv.bak/

# --- pyenv ---
.python-version

# --- IDEs & editors ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# --- Jupyter / IPython ---
.ipynb_checkpoints/
*.ipynb

# --- Secrets & local config ---
.env
.env.local
.env.*.local
*.key
*.pem

# --- Project runtime data (keep folders, ignore contents) ---
data/*
!data/.gitkeep

output/*
!output/.gitkeep

.cache/
*.wav
*.mp3
*.mp4
*.mkv
*.webm
*.avi
*.mov

# --- AI model weights (can be multi-GB) ---
*.bin
*.pt
*.pth
*.ckpt
*.safetensors

# --- Logs ---
*.log
logs/

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini
*.lnk